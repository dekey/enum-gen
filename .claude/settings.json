{
  "plansDirectory": "./docs/plans",
  "cleanupPeriodDays": 7,
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "MAX_THINKING_TOKENS": "50000",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "make format-lint"
          }
        ]
      }
    ]
  }
}
